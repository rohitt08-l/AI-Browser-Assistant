{
  "manifest_version": 3,
  "name": "AI Web Assistant",
  "version": "1.0",
  "description": "Chat with any webpage using AI",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}